		"@sendgrid/mail": "^8.1.6",
		"bulma": "^1.0.4",
		"hono": "^4.12.8",
		"mdsvex": "^0.12.7",
		"svelte-fa": "^4.0.4",
		"zod": "^4.3.6"
	}
