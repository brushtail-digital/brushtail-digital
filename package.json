		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/cloudflare-turnstile": "^0.2.2",
		"@types/eslint": "^9.6.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.98.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.5",
